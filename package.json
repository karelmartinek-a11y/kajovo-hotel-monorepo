{
  "name": "kajovo-hotel-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @kajovo/kajovo-hotel-web test",
    "ci:tokens": "node apps/kajovo-hotel/ci/lint-tokens.mjs",
    "ci:brand-assets": "node apps/kajovo-hotel/ci/lint-brand-assets.mjs",
    "ci:text-integrity": "python scripts/check_mojibake.py",
    "forensics:text-encoding": "python scripts/forensic_text_encoding_audit.py",
    "forensics:text-bulk": "python scripts/bulk_encoding_remediator.py",
    "forensics:text-gui": "python scripts/encoding_remediator_gui.py",
    "forensics:text-yolo": "python scripts/yolo_text_repair.py",
    "forensics:text-yolo-gui": "python scripts/yolo_text_repair_gui.py",
    "ci:frontend-manifest": "python scripts/check_frontend_manifest_guards.py",
    "ci:runtime-integrity": "node scripts/check_runtime_integrity.mjs",
    "ci:signage": "pnpm --filter @kajovo/kajovo-hotel-web test -- --project=desktop --grep \"SIGNACE|brand elements\" tests/ci-gates.spec.ts",
    "ci:view-states": "pnpm --filter @kajovo/kajovo-hotel-web test -- --project=desktop --grep \"state query parameter does not switch production screens\" tests/ci-gates.spec.ts",
    "ci:wcag": "pnpm --filter @kajovo/kajovo-hotel-web test -- --project=desktop --grep \"WCAG\" tests/ci-gates.spec.ts",
    "ci:gates": "pnpm ci:tokens && pnpm ci:brand-assets && pnpm ci:text-integrity && pnpm ci:frontend-manifest && pnpm ci:runtime-integrity && pnpm ci:signage && pnpm ci:view-states && pnpm ci:wcag",
    "api:generate-contract": "python apps/kajovo-hotel-api/scripts/export_openapi.py",
    "shared:generate-client": "pnpm --filter @kajovo/shared generate:client",
    "contract:generate": "pnpm api:generate-contract && pnpm shared:generate-client",
    "contract:check": "pnpm contract:generate && git diff --exit-code -- apps/kajovo-hotel-api/openapi.json packages/shared/src/generated/client.ts",
    "typecheck": "pnpm --filter @kajovo/kajovo-hotel-web lint && pnpm --filter @kajovo/kajovo-hotel-admin lint",
    "unit": "python -m pytest apps/kajovo-hotel-api/tests",
    "ci:policy": "node apps/kajovo-hotel/ci/policy-sentinel.mjs",
    "ci:verification-doc": "node apps/kajovo-hotel/ci/check-pr-verification-doc.mjs",
    "ci:parity-placeholders": "node apps/kajovo-hotel/ci/check-parity-map-placeholders.mjs",
    "ci:e2e-smoke": "pnpm --filter @kajovo/kajovo-hotel-admin test:smoke",
    "ops:smoke": "bash ./infra/smoke/smoke.sh",
    "ops:verify-deploy": "bash ./infra/verify/verify-deploy.sh"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.59.0",
      "esbuild": "0.25.0"
    }
  }
}
